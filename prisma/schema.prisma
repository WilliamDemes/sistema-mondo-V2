// ═══════════════════════════════════════════════════
// Instituto Mondó — Schema do Banco de Dados
// Governança e Gestão de Dados Sociais
// ═══════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Colaboradores do sistema ──
model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ── Famílias beneficiárias ──
model Familia {
  id              String        @id @default(uuid())
  idMondoFamilia  String        @map("id_mondo_familia")
  cidade          String
  estado          String
  grupoReferencia Grupo         @map("grupo_de_referencia")
  status          StatusFamilia  @default(ATIVA)
  observacao      String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  beneficiarios  Beneficiarios[]
  participations Participation[]

  @@map("familias")
}

enum StatusFamilia {
  ATIVA
  INATIVA
}

enum Grupo {
  APAE
  PARTEIRA
  SEMTRAS
  SAO_TOME
  MONDO
}

// ── Integrantes da família ──
model Beneficiarios {
  id              String         @id @default(uuid())
  familyId        String         @map("family_id")
  idMondoMorador  String         @map("id_mondo_morador")
  nome            String
  dataNascimento  DateTime       @map("data_nascimento")
  idade           Int
  cor             Cor
  responsavel     Responsavel          
  parentesco      Parentesco
  sexo            Sexo
  cpf             String
  createdAt       DateTime       @default(now()) @map("created_at")

  familia Familia @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("beneficiarios")
}

enum Cor {
  BRANCO
  PRETO
  PARDO
}

enum Responsavel {
  Sim
  Nao @map("Não")
}

enum Parentesco {
  PAI
  MAE
  FILHO
  FILHA
  AVO
  OUTRO
}

enum Sexo {
  Masculino
  Feminino
}


// ── Ações/Atividades do instituto ──
model Activity {
  id          String         @id @default(uuid())
  title       String
  description String?
  type        ActivityType
  format      ActivityFormat
  date        DateTime
  createdAt   DateTime       @default(now()) @map("created_at")

  participations Participation[]

  @@map("activities")
}

enum ActivityType {
  ATENDIMENTO
  ATIVIDADE
}

enum ActivityFormat {
  INDIVIDUAL
  GRUPO
}

// ── Registros de Participação ──
model Participation {
  id               String   @id @default(uuid())
  familyId         String   @map("family_id")
  activityId       String   @map("activity_id")
  participantCount Int      @default(1) @map("participant_count")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  familia   Familia   @relation(fields: [id], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("participations")
}
