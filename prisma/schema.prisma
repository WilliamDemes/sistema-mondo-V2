// ═══════════════════════════════════════════════════
// Instituto Mondó — Schema do Banco de Dados
// Governança e Gestão de Dados Sociais
// ═══════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Colaboradores do sistema ──
model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ── Famílias beneficiárias ──
model Familia {
  id           String   @id @default(uuid())
  idmondo      String
  cidade       String
  estado       String
  grupoReferencia  Grupo   @map("grupo_de_referencia")
  status       FamilyStatus @default(ATIVA)
  observacao String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  beneficiaries  Beneficiary[]
  participations Participation[]

  @@map("familias")
}

enum FamilyStatus {
  ATIVA
  INATIVA
}

enum Grupo {
  APAE
  PARTEIRA
  SEMTRAS
  SAO_TOME
}

// ── Integrantes da família ──
model Beneficiary {
  id       String         @id @default(uuid())
  familyId String         @map("family_id")
  name     String
  age      Int
  role     BeneficiaryRole
  createdAt DateTime @default(now()) @map("created_at")

  familia Familia @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("beneficiaries")
}

enum BeneficiaryRole {
  PAI
  MAE
  FILHO
  FILHA
  AVO
  OUTRO
}

// ── Ações/Atividades do instituto ──
model Activity {
  id          String         @id @default(uuid())
  title       String
  description String?
  type        ActivityType
  format      ActivityFormat
  date        DateTime
  createdAt   DateTime       @default(now()) @map("created_at")

  participations Participation[]

  @@map("activities")
}

enum ActivityType {
  ATENDIMENTO
  ATIVIDADE
}

enum ActivityFormat {
  INDIVIDUAL
  GRUPO
}

// ── Registros de Participação ──
model Participation {
  id               String   @id @default(uuid())
  familyId         String   @map("family_id")
  activityId       String   @map("activity_id")
  participantCount Int      @default(1) @map("participant_count")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  familia   Familia   @relation(fields: [id], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("participations")
}
