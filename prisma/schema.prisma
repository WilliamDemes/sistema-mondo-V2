// ═══════════════════════════════════════════════════
// Instituto Mondó — Schema do Banco de Dados
// Governança e Gestão de Dados Sociais
// ═══════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Colaboradores do sistema ──
model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ── Famílias beneficiárias ──
model Familia {
  id              String        @id @default(uuid())
  idMondoFamilia  String        @map("id_mondo_familia")
  cidade          String
  estado          String
  grupoReferencia Grupo         @map("grupo_de_referencia")
  status          StatusFamilia  @default(ATIVA)
  observacao      String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  beneficiarios  Beneficiarios[]
  participacoes Participacoes[]

  @@map("familias")
}

enum StatusFamilia {
  ATIVA
  INATIVA
}

enum Grupo {
  APAE
  PARTEIRA
  SEMTRAS
  SAO_TOME
  MONDO
}

// ── Integrantes da família ──
model Beneficiarios {
  id              String         @id @default(uuid())
  familyId        String         @map("family_id")
  idMondoMorador  String         @map("id_mondo_morador")
  nome            String
  dataNascimento  DateTime       @map("data_nascimento")
  idade           Int
  cor             Cor
  responsavel     Responsavel          
  parentesco      Parentesco
  sexo            Sexo
  cpf             String?
  createdAt       DateTime       @default(now()) @map("created_at")

  familia Familia @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("beneficiarios")
}

enum Cor {
  BRANCO
  PRETO
  PARDO
  INDIGENA
  AMARELO
}

enum Responsavel {
  Sim
  Nao
}

enum Parentesco {
  PAI
  MAE
  FILHO
  AVO
  CONJUGE
  RESPONSAVEL
  SOBRINHO
  NETO
  IRMAO    
  TIO
  ENTEADO
  NAO_COLETADO  @map("NAO COLETADO")
  OUTRO
}

enum Sexo {
  Masculino
  Feminino
  Outro_ou_Não_declarou  @map("Outro/Nao declarou")
}


// ── Ações/Atividades do instituto ──
model Activity {
  id          String         @id @default(uuid())
  nomeAcao    String         @map("nome_acao")
  descricao   String?        
  dimensao    Dimensao
  projeto     Projeto
  tipo        TipoAtividade  @map("tipo_de_acao")
  formato     FormatoAtividade    @map("formato_da_atividade")
  local       String
  semestre    String
  date        DateTime
  createdAt   DateTime       @default(now()) @map("created_at")

  participacoes Participacoes[]

  @@map("acoes")
}

enum Dimensao {
  EDUCACAO  @map("EDUCACÃO")
  SAUDE  @map("SAÚDE")
  MAE     @map("MORADIA_ÁGUA_ENERGIA")
  DESENVOLVIMENTO_ECONOMICO   @map("DESENVOLVIMENTO_ECONOMICO")
  NUTRICAO    @map("NUTRIÇÃO")
}

enum Projeto {
  REDEMAIS    @map("REDE+")
  PROA
}

enum TipoAtividade {
  ATENDIMENTO
  ATIVIDADE
}

enum FormatoAtividade {
  INDIVIDUAL
  GRUPO
}


// ── Registros de Participação ──
model Participacoes {
  id                    String   @id @default(uuid())
  familiaId             String   @map("familia_id")
  acaoId                String   @map("acao_id")
  contagemParticipantes Int      @default(1) @map("contagem_de_participantes")
  Observacoes           String?
  createdAt             DateTime @default(now()) @map("created_at")

  familia   Familia   @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [acaoId], references: [id], onDelete: Cascade)

  @@map("participacoes")
}
