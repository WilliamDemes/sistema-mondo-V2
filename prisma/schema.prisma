// ═══════════════════════════════════════════════════
// Instituto Mondó — Schema do Banco de Dados
// Governança e Gestão de Dados Sociais
// ═══════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

// ── Colaboradores do sistema ──
model User {
  idSistema    String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String   @map("password_hash")
  criadoEm    DateTime @default(now()) @map("criado_em")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ── Famílias beneficiárias ──
model Familia {
  id_sistema      String        @id @default(dbgenerated("gen_random_uuid()")) @map("id_sistema")
  idFamilia       String        @unique @map("id_familia")
  cidade          String
  estado          String
  grupoReferencia Grupo         @map("grupo_de_referencia")
  status          StatusFamilia  @default(ATIVA)
  observacao      String?
  criadoEm        DateTime      @default(now()) @map("criado_em")
  atualizadoEm    DateTime      @updatedAt @map("atualizado_em")

  beneficiarios  Beneficiarios[]
  participacoes Participacoes[]

  @@map("familias")
}

enum StatusFamilia {
  ATIVA
  INATIVA
}

enum Grupo {
  APAE
  PARTEIRA
  SEMTRAS
  SAO_TOME
  MONDO
}

// ── Integrantes da família ──
model Beneficiarios {
  idSistema          String        @id @default(dbgenerated("gen_random_uuid()")) @map("id_sistema")
  idFamilia          String        @map("id_familia")
  sequencialMorador  String        @map("sequencial_morador")
  nome               String
  dataNascimento     DateTime      @map("data_nascimento")
  idade              Int
  cor                Cor
  responsavel        Responsavel          
  parentesco         Parentesco
  sexo               Sexo
  cpf                String?
  criadoEm           DateTime       @default(now()) @map("criado_em")

  familia Familia @relation(fields: [idFamilia], references: [idFamilia], onDelete: Cascade)

  @@map("beneficiarios")
}

enum Cor {
  BRANCO
  PRETO
  PARDO
  INDIGENA
  AMARELO
}

enum Responsavel {
  Sim
  Nao
}

enum Parentesco {
  PAI
  MAE
  FILHO
  AVO
  CONJUGE
  RESPONSAVEL
  SOBRINHO
  NETO
  IRMAO    
  TIO
  ENTEADO
  NAO_COLETADO  @map("NAO COLETADO")
  OUTRO
}

enum Sexo {
  Masculino
  Feminino
  Outro_ou_Não_declarou  @map("Outro/Nao declarou")
}


// ── Ações/Atividades do instituto ──
model Acoes {
  idAcao      String         @id @default(uuid())
  nomeAcao    String         @map("nome_acao")
  descricao   String?        
  dimensao    Dimensao
  rubrica     String
  projeto     Projeto
  categoria   Categoria  @map("categoria")
  formato     FormatoAtividade    @map("formato_da_atividade")
  local       String
  semestre    String
  data        DateTime
  metadados   Json?
  criadoEm   DateTime       @default(now()) @map("criado_em")

  participacoes Participacoes[]

  @@map("acoes")
}

enum Dimensao {
  EDUCACAO                    @map("EDUCACÃO")
  SAUDE                       @map("SAÚDE")
  MAE                         @map("MORADIA_ÁGUA_ENERGIA")
  DESENVOLVIMENTO_ECONOMICO   @map("DESENVOLVIMENTO_ECONOMICO")
  NUTRICAO                    @map("NUTRIÇÃO")
}

enum Projeto {
  REDEMAIS    @map("REDE+")
  PROA
}

enum Categoria {
  ATENDIMENTO
  ATIVIDADE
}

enum FormatoAtividade {
  INDIVIDUAL
  GRUPO
}


// ── Registros de Participação ──
model Participacoes {
  idParticipacao        String   @id @default(uuid()) @map("id_participacao")
  idFamilia             String   @map("id_familia")
  idAcao                String   @map("id_acao")
  sequencialMorador     String   @map("sequencial_morador")
  contagemParticipantes Int      @default(1) @map("contagem_de_participantes")
  observacoes           String?
  criadoEm             DateTime @default(now()) @map("criado_em")

  familia   Familia   @relation(fields: [idFamilia], references: [idFamilia], onDelete: Cascade)
  acoes Acoes @relation(fields: [idAcao], references: [idAcao], onDelete: Cascade)

  @@map("participacoes")
}

// ---- ACOMPANHAMENTO FAMILIAR ------
model acompanhamentoFamiliar {
  id              Int      @id @default(autoincrement())
  idFamilia       Int      
  dataVisita      DateTime
  visitador       String
  rua             String?
  numero          String?
  bairro          String?
  telefone        String?
  statusEndereco  String?
  criadoEm        DateTime @default(now())

  // Relacionamento com a tabela Familia (opcional, mas recomendado)
  // familia      Familia  @relation(fields: [idFamilia], references: [id])

  @@map("acompanhamento_familiar")
}

// ── Tabela de Ciclos de Coleta Neon ──
model CicloColeta {
  id_sistema                  String  @id @default(dbgenerated("gen_random_uuid()")) @map("id_sistema")
  
  domiCod                     Int?    @map("DOMI_COD")
  domiDt                      String? @map("DOMI_DT") // Mantido como texto para facilitar importação (DD/MM/YYYY)
  domiElegibilidade           Int?    @map("DOMI_ELEGIBILIDADE")
  domiFase                    Int?    @map("DOMI_FASE")
  domiRodada                  Int?    @map("DOMI_RODADA")
  domiMeses                   Int?    @map("DOMI_MESES")
  nomeFantasia                String? @map("NOME_FANTASIA")
  grupoInstituicao            String? @map("GRUPO_INSTITUICAO")
  domiNumColeta               Int?    @map("DOMI_NUM_COLETA")
  domiNumColetaRev            Int?    @map("DOMI_NUM_COLETA_REV")
  lastImpoDt                  String? @map("LAST_IMPO_DT")
  bairro                      String? @map("BAIRRO")
  municipio                   String? @map("MUNICIPIO")
  uf                          String? @map("UF")
  gps                         String? @map("GPS")
  latitude                    Float?  @map("LATITUDE")
  longitude                   Float?  @map("LONGITUDE")
  subcodigo                   String? @map("SUBCODIGO")
  residentes                  Int?    @map("RESIDENTES")
  menores                     Int?    @map("MENORES")
  adultos                     Int?    @map("ADULTOS")
  rendaMoradores              Int?    @map("RENDA_MORADORES")
  rendaTotal                  Int?    @map("RENDA_TOTAL")
  rendaPerCapta               Int?    @map("RENDA_PER_CAPTA")
  
  // Variáveis de Indicadores (Mapeamento Direto)
  domiR1                      Int?    @map("DOMI_R1")
  domiR2                      Int?    @map("DOMI_R2")
  domiE1                      Int?    @map("DOMI_E1")
  domiE1A                     Int?    @map("DOMI_E1_A")
  domiE1B                     Int?    @map("DOMI_E1_B")
  domiE2                      Int?    @map("DOMI_E2")
  domiE2A                     Int?    @map("DOMI_E2_A")
  domiE2B                     Int?    @map("DOMI_E2_B")
  domiI1                      Int?    @map("DOMI_I1")
  domiI2                      Int?    @map("DOMI_I2")
  domiI2A                     Int?    @map("DOMI_I2_A")
  domiI2B                     Int?    @map("DOMI_I2_B")
  domiI3                      Int?    @map("DOMI_I3")
  domiI3A                     Int?    @map("DOMI_I3_A")
  domiI3B                     Int?    @map("DOMI_I3_B")
  domiI3C                     Int?    @map("DOMI_I3_C")
  domiI3D                     Int?    @map("DOMI_I3_D")
  domiI4                      Int?    @map("DOMI_I4")
  domiS1                      Int?    @map("DOMI_S1")
  domiS1A                     Int?    @map("DOMI_S1_A")
  domiS1B                     Int?    @map("DOMI_S1_B")
  domiS1C                     Int?    @map("DOMI_S1_C")
  domiS1D                     Int?    @map("DOMI_S1_D")
  domiN1                      Int?    @map("DOMI_N1")
  domiN1A                     Int?    @map("DOMI_N1_A")
  domiN1B                     Int?    @map("DOMI_N1_B")
  
  // Status Sociais e Ambientais
  domiIndicador               Int?    @map("DOMI_INDICADOR")
  domiInsegurancaAlimentar    Int?    @map("DOMI_INSEGURANCA_ALIMENTAR")
  domiIsAguaCanalizada        Int?    @map("DOMI_IS_AGUA_CANALIZADA")
  domiIsAguaTratada           Int?    @map("DOMI_IS_AGUA_TRATADA")
  domiIsNotAguaRede           Int?    @map("DOMI_IS_NOT_AGUA_REDE")
  domiIsImprovisado           Int?    @map("DOMI_IS_IMPROVISADO")
  domiIsRiscoAmbiental        Int?    @map("DOMI_IS_RISCO_AMBIENTAL")
  domiIsAdultoSemEf           Int?    @map("DOMI_IS_ADULTO_SEM_EF")
  domiAnalfabetos             Int?    @map("DOMI_ANALFABETOS")
  domiIsRiscoExclusao         Int?    @map("DOMI_IS_RISCO_EXCLUSAO")
  domiIsDeficiencia           Int?    @map("DOMI_IS_DEFICIENCIA")
  domiIsDeficienciaSemLaudo   Int?    @map("DOMI_IS_DEFICIENCIA_SEM_LAUDO")
  domiIsDeficienciaSemBpc     Int?    @map("DOMI_IS_DEFICIENCIA_SEM_BPC")
  domiIsDoenca                Int?    @map("DOMI_IS_DOENCA")
  domiIsCuidadoMoradores      Int?    @map("DOMI_IS_CUIDADO_MORADORES")
  domiMenorSemEscola          Int?    @map("DOMI_MENOR_SEM_ESCOLA")
  domiDtCadunico              String? @map("DOMI_DT_CADUNICO")
  domiIsChefiaMulheres        Int?    @map("DOMI_IS_CHEFIA_MULHERES")
  domiIsSemColetaLixo         Int?    @map("DOMI_IS_SEM_COLETA_LIXO")
  domiIsGrupoArmado           Int?    @map("DOMI_IS_GRUPO_ARMADO")
  domiIsOcupacao              Int?    @map("DOMI_IS_OCUPACAO")
  domiIsIdosoSemAposentadoria Int?    @map("DOMI_IS_IDOSO_SEM_APOSENTADORIA")
  domiIsMenorSemCartaoVacinal Int?    @map("DOMI_IS_MENOR_SEM_CARTAO_VACINAL")
  domiEmprestimos             Int?    @map("DOMI_EMPRESTIMOS")
  domiIsAdultosComEf          Int?    @map("DOMI_IS_ADULTOS_COM_EF")
  domiIsMaeSolo               Int?    @map("DOMI_IS_MAE_SOLO")

  criadoEm                    DateTime @default(now()) @map("criado_em")

  @@map("ciclos_de_coleta")
}

// ---------- INDICADORES --------------
model Indicadores {
  idIndicador         String    @id @map("id_indicador")
  dimensao            String
  tipo                String
  indicadorOficial    String    @map("indicador_oficial")
  peso                Int?
  indicadorResumido   String    @map("indicador_resumido")

  @@map("indicadores")
}

// ---- TABELAS VIRTUAIS (VIEW) ---------

view IndicadoresTranspostos {
  domiRodada        Int?    @map("DOMI_RODADA")
  domiCod           Int     @map("DOMI_COD")
  indicador         String  @map("indicadores")
  violacao          Int?    @map("violacoes")
  tipo              String? @map("tipo")
  dimensao          String
  indicadorResumido String  @map("indicador_resumido")
  
  @@unique([domiCod, indicador])

  @@map("indicadores_transpostos")
}